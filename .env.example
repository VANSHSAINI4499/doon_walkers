SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Web OAuth client ID from Google Cloud Console (client_type 3 in
# android/app/google-services.json) — NOT the Android client ID. This is
# what google_sign_in's serverClientId uses so the ID token's audience
# matches what Supabase's Google provider verifies against.
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# MSG91 OTP Widget credentials (MSG91 dashboard → OTP Widget → widget
# config). These are NOT server secrets — sendotp_flutter_sdk calls
# MSG91 directly from the device, so both values ship inside the app
# binary by design (MSG91_WIDGET_TOKEN_AUTH is a scoped, widget-specific
# token deliberately meant to be client-embeddable, distinct from the
# account-wide MSG91_AUTH_KEY, which stays a server-only Supabase secret
# and must never go in this file).
MSG91_WIDGET_ID=your-widget-id
MSG91_WIDGET_TOKEN_AUTH=your-widget-token-auth
